[user]
  name = Drew Reeve
  email = dru.reeve@gmail.com
[alias]
  ci = commit --verbose
  co = checkout
  aa = add --all
  ap = add --patch
  ca = commit --amend
  trust = "!mkdir -p .git/safe"
  st = status -sb
  lg = log --graph --oneline --decorate
[branch]
  sort = -committerdate
[column]
  ui = auto
[commit]
  verbose = true
[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true
[core]
  excludesfile = ~/.config/git/ignore
  autocrlf = input
[init]
  defaultBranch = main
[include]
  path = ~/.gitconfig.local
[color]
  status = auto
  branch = auto
  ui = auto
[help]
  autocorrect = 0
[rebase]
  autosquash = true
[push]
	autoSetupRemote = true
	followTags = true
[rerere]
  enabled = true
  autoupdate = true
[merge]
	conflictstyle = zdiff3
